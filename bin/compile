#!/usr/bin/env bash
# bin/compile <build-dir> <cache-dir> <env-dir>
# Compiles a Flutter web application for Scalingo

set -eo pipefail

# -------- Arguments --------
BUILD_DIR="${1}"
CACHE_DIR="${2}"
ENV_DIR="${3}"

# -------- Helper functions --------
indent() {
  sed -u 's/^/       /'
}

export_env_dir() {
  local env_dir="${1}"
  if [ -d "${env_dir}" ]; then
    for e in $(ls "${env_dir}" 2>/dev/null); do
      case "${e}" in
        FLUTTER_VERSION|FLUTTER_BUILD_ARGS|FLUTTER_CLEANUP|FLUTTER_SOURCE_DIR|FLUTTER_DEPLOY_DIR|FLUTTER_CHANNEL|PUB_CACHE)
          export "${e}=$(cat "${env_dir}/${e}")"
          echo "       env: ${e}=$(cat "${env_dir}/${e}")" 
          ;;
      esac
    done
  fi
}

# Build --dart-define arguments from individual env vars
# Reads: API_BASE_URL, ENVIRONMENT, DEBUG, HTTP_TIMEOUT, API_KEY, and any DART_DEFINE_* variable
build_dart_defines() {
  local env_dir="${1}"
  local dart_defines=""
  
  if [ ! -d "${env_dir}" ]; then
    echo ""
    return
  fi
  
  # Explicit well-known variables to inject
  local known_vars="API_BASE_URL ENVIRONMENT DEBUG HTTP_TIMEOUT API_KEY API_CERT_PIN_SHA1"
  
  for var in ${known_vars}; do
    if [ -f "${env_dir}/${var}" ]; then
      local val
      val=$(cat "${env_dir}/${var}")
      dart_defines="${dart_defines} --dart-define=${var}=${val}"
      echo "       dart-define: ${var}=${val}" >&2
    fi
  done
  
  # Also read any DART_DEFINE_* variables (generic escape hatch)
  # e.g. DART_DEFINE_MY_VAR=hello → --dart-define=MY_VAR=hello
  for f in $(ls "${env_dir}" 2>/dev/null); do
    case "${f}" in
      DART_DEFINE_*)
        local var_name="${f#DART_DEFINE_}"
        local val
        val=$(cat "${env_dir}/${f}")
        dart_defines="${dart_defines} --dart-define=${var_name}=${val}"
        echo "       dart-define: ${var_name}=${val}" >&2
        ;;
    esac
  done
  
  echo "${dart_defines}"
}

# -------- Load environment variables --------
echo "-----> Loading environment variables..."
export_env_dir "${ENV_DIR}"

# -------- Configuration (with defaults) --------
FLUTTER_CHANNEL="${FLUTTER_CHANNEL:-stable}"
FLUTTER_VERSION="${FLUTTER_VERSION:-3.24.0}"
FLUTTER_BUILD_ARGS="${FLUTTER_BUILD_ARGS:---release}"
FLUTTER_CLEANUP="${FLUTTER_CLEANUP:-true}"
FLUTTER_SOURCE_DIR="${FLUTTER_SOURCE_DIR:-}"
FLUTTER_DEPLOY_DIR="${FLUTTER_DEPLOY_DIR:-build/web}"

echo "-----> Flutter Web Buildpack for Scalingo"
echo "       Flutter version: ${FLUTTER_VERSION}"
echo "       Channel: ${FLUTTER_CHANNEL}"
echo "       Build args: ${FLUTTER_BUILD_ARGS}"
echo "       Cleanup: ${FLUTTER_CLEANUP}"

# -------- Cache management --------
mkdir -p "${CACHE_DIR}"

PUB_CACHE_DIR="${CACHE_DIR}/pub-cache"
mkdir -p "${PUB_CACHE_DIR}"
export PUB_CACHE="${PUB_CACHE_DIR}"

# -------- Install Flutter SDK --------
FLUTTER_SDK_DIR="${CACHE_DIR}/flutter-sdk"
FLUTTER_SDK_VERSION_FILE="${FLUTTER_SDK_DIR}/.flutter-buildpack-version"

install_flutter_git() {
  local version="${1}"
  echo "-----> Installing Flutter ${version} via git clone..."
  rm -rf "${FLUTTER_SDK_DIR}"
  
  if git clone --depth 1 --branch "${version}" https://github.com/flutter/flutter.git "${FLUTTER_SDK_DIR}" 2>&1 | indent; then
    echo "       Git clone successful"
  else
    echo "       ERROR: git clone failed for version ${version}"
    echo "       Trying without specific tag..."
    rm -rf "${FLUTTER_SDK_DIR}"
    git clone --depth 1 https://github.com/flutter/flutter.git "${FLUTTER_SDK_DIR}" 2>&1 | indent
    cd "${FLUTTER_SDK_DIR}"
    git fetch --depth 1 origin "refs/tags/${version}:refs/tags/${version}" 2>&1 | indent || true
    git checkout "${version}" 2>&1 | indent || echo "       WARNING: Could not checkout ${version}, using default branch"
    cd "${BUILD_DIR}"
  fi
  
  echo "${version}" > "${FLUTTER_SDK_VERSION_FILE}"
}

install_flutter_archive() {
  local version="${1}"
  local sdk_url="https://storage.googleapis.com/flutter_infra_release/releases/stable/linux/flutter_linux_${version}-stable.tar.xz"
  
  echo "-----> Downloading Flutter SDK ${version} from archive..."
  echo "       URL: ${sdk_url}"
  
  rm -rf "${FLUTTER_SDK_DIR}"
  mkdir -p "${CACHE_DIR}/flutter-download"
  
  if curl -sL --fail -o "${CACHE_DIR}/flutter-download/flutter.tar.xz" "${sdk_url}" 2>&1; then
    echo "       Download successful, extracting..."
    cd "${CACHE_DIR}/flutter-download"
    tar xJf flutter.tar.xz 2>&1 | indent
    
    if [ -d "${CACHE_DIR}/flutter-download/flutter" ]; then
      mv "${CACHE_DIR}/flutter-download/flutter" "${FLUTTER_SDK_DIR}"
      echo "       Extraction successful"
    else
      echo "       ERROR: Extraction did not produce expected directory"
      rm -rf "${CACHE_DIR}/flutter-download"
      return 1
    fi
    
    rm -rf "${CACHE_DIR}/flutter-download"
    cd "${BUILD_DIR}"
    echo "${version}" > "${FLUTTER_SDK_VERSION_FILE}"
  else
    echo "       Archive download failed, falling back to git..."
    rm -rf "${CACHE_DIR}/flutter-download"
    cd "${BUILD_DIR}"
    return 1
  fi
}

# Check if we have the right version cached
NEED_INSTALL=true
if [ -f "${FLUTTER_SDK_VERSION_FILE}" ]; then
  CACHED_VERSION=$(cat "${FLUTTER_SDK_VERSION_FILE}")
  if [ "${CACHED_VERSION}" = "${FLUTTER_VERSION}" ] && [ -f "${FLUTTER_SDK_DIR}/bin/flutter" ]; then
    echo "-----> Using cached Flutter SDK ${FLUTTER_VERSION}"
    NEED_INSTALL=false
  else
    echo "-----> Cached version (${CACHED_VERSION}) differs or SDK incomplete, reinstalling..."
  fi
fi

if [ "${NEED_INSTALL}" = "true" ]; then
  # Try archive first, fall back to git
  install_flutter_archive "${FLUTTER_VERSION}" || install_flutter_git "${FLUTTER_VERSION}"
fi

# Verify SDK exists
if [ ! -f "${FLUTTER_SDK_DIR}/bin/flutter" ]; then
  echo "ERROR: Flutter SDK installation failed - bin/flutter not found" | indent
  ls -la "${FLUTTER_SDK_DIR}/" 2>&1 | indent || echo "       SDK dir does not exist"
  exit 1
fi

# -------- Set up PATH --------
export PATH="${FLUTTER_SDK_DIR}/bin:${FLUTTER_SDK_DIR}/bin/cache/dart-sdk/bin:${PATH}"

# -------- Verify Flutter installation --------
echo "-----> Verifying Flutter installation..."
flutter --version 2>&1 | indent

# -------- Enable web support --------
echo "-----> Enabling Flutter web support..."
flutter config --enable-web 2>&1 | indent || echo "       (config --enable-web not needed for this version)" | indent

# -------- Pre-cache web build tools --------
echo "-----> Pre-caching web build tools..."
flutter precache --web 2>&1 | indent

# -------- Resolve source directory --------
if [ -n "${FLUTTER_SOURCE_DIR}" ]; then
  SOURCE_DIR="${BUILD_DIR}/${FLUTTER_SOURCE_DIR}"
else
  SOURCE_DIR="${BUILD_DIR}"
fi

if [ ! -f "${SOURCE_DIR}/pubspec.yaml" ]; then
  echo "ERROR: pubspec.yaml not found in ${SOURCE_DIR}" | indent
  exit 1
fi

cd "${SOURCE_DIR}"
echo "-----> Working directory: $(pwd)"

# -------- Install dependencies --------
echo "-----> Installing Flutter dependencies (pub get)..."
flutter pub get 2>&1 | indent

# -------- Build dart-define arguments from env vars --------
echo "-----> Resolving --dart-define variables..."
DART_DEFINE_ARGS=$(build_dart_defines "${ENV_DIR}")

# -------- Build the web app --------
echo "-----> Building Flutter web application..."
FULL_BUILD_ARGS="${FLUTTER_BUILD_ARGS}${DART_DEFINE_ARGS}"
echo "       Command: flutter build web ${FULL_BUILD_ARGS}"
flutter build web ${FULL_BUILD_ARGS} 2>&1 | indent

# -------- Verify build output --------
WEB_BUILD_DIR="${SOURCE_DIR}/build/web"

if [ ! -d "${WEB_BUILD_DIR}" ]; then
  echo "ERROR: Build output not found at ${WEB_BUILD_DIR}" | indent
  exit 1
fi

echo "       Build output size: $(du -sh "${WEB_BUILD_DIR}" | cut -f1)"

# -------- Deploy built files --------
DEPLOY_TARGET="${BUILD_DIR}/${FLUTTER_DEPLOY_DIR}"

if [ "${WEB_BUILD_DIR}" != "${DEPLOY_TARGET}" ]; then
  echo "-----> Copying build output to ${FLUTTER_DEPLOY_DIR}..."
  mkdir -p "${DEPLOY_TARGET}"
  cp -R "${WEB_BUILD_DIR}/"* "${DEPLOY_TARGET}/"
fi

# -------- Cleanup --------
if [ "${FLUTTER_CLEANUP}" = "true" ]; then
  echo "-----> Cleaning up to reduce slug size..."
  
  # Remove dart/flutter build caches from the build dir
  find "${BUILD_DIR}" -name ".dart_tool" -type d -exec rm -rf {} + 2>/dev/null || true
  find "${BUILD_DIR}" -name ".packages" -type f -delete 2>/dev/null || true
  
  # Remove source code directories not needed at runtime
  rm -rf "${BUILD_DIR}/android" 2>/dev/null || true
  rm -rf "${BUILD_DIR}/ios" 2>/dev/null || true
  rm -rf "${BUILD_DIR}/linux" 2>/dev/null || true
  rm -rf "${BUILD_DIR}/macos" 2>/dev/null || true
  rm -rf "${BUILD_DIR}/windows" 2>/dev/null || true
  rm -rf "${BUILD_DIR}/test" 2>/dev/null || true
  rm -rf "${BUILD_DIR}/lib" 2>/dev/null || true
  
  echo "       Cleanup complete"
fi

# -------- Create .profile.d script --------
mkdir -p "${BUILD_DIR}/.profile.d"
cat > "${BUILD_DIR}/.profile.d/flutter.sh" << 'PROFILE'
# Flutter web runtime - no SDK needed, only static files served
export PATH="/app/bin:${PATH}"
PROFILE

echo "-----> Flutter web build complete!"
echo "       Output directory: ${FLUTTER_DEPLOY_DIR}"
echo "       Ready for Nginx to serve"
